{
  "name": "developertools",
  "version": "2.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf .next node_modules",
    "compress": "chmod +x scripts/compress-assets.sh && ./scripts/compress-assets.sh",
    "build:prod": "npm run build && npm run compress",
    "analyze": "ANALYZE=true npm run build",
    "perf": "npm run build && npm run start",
    "seo:collect": "tsx scripts/seo/collect.ts",
    "seo:diagnose": "tsx scripts/seo/diagnose.ts",
    "seo:apply": "tsx scripts/seo/apply.ts",
    "seo:report": "tsx scripts/seo/report.ts",
    "seo:full": "npm run seo:collect && npm run seo:diagnose && npm run seo:apply && npm run seo:report",
    "sitemap": "next-sitemap"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/qrcode": "^1.5.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "cron-parser": "^5.4.0",
    "cronstrue": "^2.61.0",
    "diff": "^8.0.2",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.575.0",
    "marked": "^16.4.0",
    "next": "15.5.12",
    "next-google-adsense": "^1.1.0",
    "next-intl": "^4.8.3",
    "next-seo": "^7.0.1",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "18",
    "react-dom": "18",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.12",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
