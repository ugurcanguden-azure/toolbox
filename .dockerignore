# 🚀 Optimized .dockerignore for Performance
# Excludes unnecessary files to reduce image size and build time

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store

# Testing
coverage
.nyc_output
__tests__
*.test.js
*.test.ts
*.test.tsx
*.spec.js
*.spec.ts
*.spec.tsx

# Next.js
.next/
out/
build
dist

# Production
.vercel
.netlify

# 🗜️ Compression artifacts (will be generated during build)
*.gz
*.br

# Misc
.DS_Store
*.pem
*.log
*.tmp
*.temp

# Debug
*.tsbuildinfo
next-env.d.ts

# Local env files
.env
.env*.local

# Editor
.vscode
.idea
*.swp
*.swo
*~

# Git
.git
.gitignore
.gitattributes

# 📚 Documentation (exclude to reduce image size)
README.md
CONTRIBUTING.md
ROADMAP.md
GETTING_STARTED.md
PROJECT_SUMMARY.md
DEPLOYMENT.md
DOCKER_QUICK_START.md
AZURE_PIPELINE_SETUP.md
NGINX_CONFIG.md
PERFORMANCE-OPTIMIZATION.md
.cursorrules
.cursor

# CI/CD (exclude from image)
.github
.gitlab-ci.yml
Dockerfile
docker-compose*.yml
docker-build.sh
azure-pipelines.yml

# 🚀 Performance monitoring (exclude from production)
lighthouse-ci.json
.nyc_output

# 📊 Development tools
.eslintrc*
.prettierrc*
jest.config*
cypress/
playwright/

# 🗂️ Temporary files
*.cache
.cache/
.temp/
tmp/